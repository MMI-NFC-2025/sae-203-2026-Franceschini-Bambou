---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '@fontsource-variable/alumni-sans-sc';
import '../styles/global.css';
 
interface Props {
	title?: string;
}

const { title = "Jumelages" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<link rel="icon" type="image/svg+xml" href="/assets/icones/favicon/favicon.svg" />
		<link rel="shortcut icon" href="/assets/icones/favicon/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/assets/icones/favicon/apple-touch-icon.png" />
		<link rel="manifest" href="/assets/icones/favicon/site.webmanifest" />
	</head>
	<body class="bg-white text-black var(--font-family) m-0 p-0">
		<Header />	
		<main class="m-0 p-0 w-full">
			<slot /> 
		</main>
		<Footer />
	</body>
</html>

