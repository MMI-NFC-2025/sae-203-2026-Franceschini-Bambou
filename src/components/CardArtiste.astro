---
import { getImageUrl } from '../../backend/backend.mjs';
import PocketBase from 'pocketbase';

const { artiste } = Astro.props;
const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL || 'http://localhost:8090';
const pb = new PocketBase(pbUrl);

if (!artiste) {
  throw new Error('CardArtiste require une prop "artiste"');
}

let sceneName = '';
if (artiste.scene) {
  try {
    const scene = await pb.collection('scene').getOne(artiste.scene);
    sceneName = scene.nom || '';
  } catch (e) {
    console.warn(`Impossible de récupérer la scène pour l'artiste ${artiste.nom}`);
  }
}

const formatDate = (date_de_representation?: string) => {
  if (!date_de_representation) return '';
  try {
    const date = new Date(date_de_representation);
    const formatter = new Intl.DateTimeFormat('fr-FR', {
      day: '2-digit',
      month: 'long',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    });
    const parts = formatter.formatToParts(date);
    const day = parts.find(p => p.type === 'day')?.value;
    const month = parts.find(p => p.type === 'month')?.value?.toUpperCase();
    const hour = parts.find(p => p.type === 'hour')?.value;
    const minute = parts.find(p => p.type === 'minute')?.value;
    return `${day} ${month} ${hour}H${minute}`;
  } catch (e) {
    return '';
  }
};

const imageUrl = artiste.photo ? getImageUrl(artiste, artiste.photo) : '';
---

<a href={`/artistes/${artiste.id}`} class="group cursor-pointer">
  <div class="flex flex-col items-center h-full hover:translate-y-[-4px] transition duration-300">
    <div class="w-32 h-32 overflow-hidden border-4 border-slate-900 shadow-lg mb-6 group-hover:shadow-xl transition">
      {imageUrl ? (
        <img 
          src={imageUrl}
          alt={artiste.nom || 'Artiste'}
          class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
        />
      ) : (
        <div class="w-full h-full bg-gray-300 flex items-center justify-center text-gray-600 text-xs font-semibold">
          {artiste.nom || 'Artiste'}
        </div>
      )}
    </div>

    <h3 class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-wide line-clamp-2 group-hover:text-blue-600 transition">
      {artiste.nom}
    </h3>

    <p class="text-sm text-slate-900 font-semibold mb-2">
      {formatDate(artiste.date_de_representation)}
    </p>

    <p class="text-sm text-slate-900 font-semibold uppercase tracking-wide">
      {artiste.scene ? sceneName : 'Scène non renseignée'}
    </p>
  </div>
</a>