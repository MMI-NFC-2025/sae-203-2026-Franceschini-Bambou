---
interface Props {
  images: string[];
  artisteName?: string;
}

const { images, artisteName = "Artiste" } = Astro.props;
---

{images && images.length > 0 && (
  <!-- Carousel Section -->
  <section class="relative w-full bg-white py-12 px-0 m-0 mb-12">

    <div class="relative flex items-center justify-center px-4 sm:px-6 md:px-12">
      <button 
        class="absolute left-0 sm:left-2 z-10 w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center bg-white rounded-full hover:bg-gray-200 transition-colors shadow-lg shrink-0" 
        id="prevBtn" 
        aria-label="Défiler vers la gauche"
      >
        <img src="/assets/icones/bouton/fleche-gauche.svg" alt="fleche gauche" class="w-6 h-6" />
      </button>

      <!-- Carousel Container -->
      <div class="carousel__container flex gap-4 overflow-x-scroll snap-x snap-mandatory scroll-smooth w-full max-w-4xl mx-auto" id="carouselContainer" style="scroll-padding: 2rem;">
        {images.map((imageUrl) => (
          <div class="carousel__item shrink-0 snap-center w-full h-96">
            <img 
              src={imageUrl} 
              alt={`Galerie ${artisteName}`} 
              class="w-full h-full object-cover rounded-lg shadow-lg" 
            />
          </div>
        ))}
      </div>

      <!-- Right navigation button -->
      <button 
        class="absolute right-0 sm:right-2 z-10 w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center bg-white rounded-full hover:bg-gray-200 transition-colors shadow-lg shrink-0" 
        id="nextBtn" 
        aria-label="Défiler vers la droite"
      >
        <img src="/assets/icones/bouton/fleche-droite.svg" alt="fleche droite" class="w-6 h-6" />
      </button>
    </div>
  </section>
)}

<script>
  const carouselContainer = document.getElementById('carouselContainer');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  if (carouselContainer && prevBtn && nextBtn) {
    const scrollAmount = 400;

    prevBtn.addEventListener('click', () => {
      carouselContainer.scrollBy({
        left: -scrollAmount,
        behavior: 'smooth',
      });
    });

    nextBtn.addEventListener('click', () => {
      carouselContainer.scrollBy({
        left: scrollAmount,
        behavior: 'smooth',
      });
    });
  }
</script>
