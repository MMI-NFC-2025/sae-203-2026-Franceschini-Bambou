---
import Layout from '../layouts/Layout.astro';
import { artistesSorted, scenesName } from '../../backend/backend.mjs';

const artistes = await artistesSorted();
const scenes = await scenesName();

const sceneMap = new Map();
scenes.forEach((s: any) => sceneMap.set(s.id, s.nom));

const grouped = new Map<string, any[]>();
artistes.forEach((a: any) => {
	const date = new Date(a.date_de_representation);
	const dayKey = date.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
	if (!grouped.has(dayKey)) grouped.set(dayKey, []);
	grouped.get(dayKey)!.push(a);
});

const formatHeure = (dateStr: string) => {
	const d = new Date(dateStr);
	const h = d.getHours().toString().padStart(2, '0');
	const m = d.getMinutes().toString().padStart(2, '0');
	return `${h}h${m}`;
};
---

<Layout title="Jumelages - Programme">
	<section class="w-full py-12 px-4">
		<h1 class="text-4xl sm:text-5xl font-bold text-slate-900 text-center mb-12 uppercase tracking-wide">
			Programme
		</h1>
		<p class="text-lg text-slate-700 text-center mb-10 px-4 max-w-3xl mx-auto">
			Découvrez le programme complet du festival, avec les horaires et les scènes pour chaque représentation.
		</p>

		{[...grouped.entries()].map(([jour, artistesJour]) => (
			<div class="max-w-4xl mx-auto mb-12">
				<h2 class="text-2xl sm:text-3xl font-bold text-slate-900 uppercase tracking-wide mb-6 text-center">
					{jour}
				</h2>
				<div class="overflow-x-auto rounded-lg shadow-lg">
					<table class="w-full border-collapse bg-white">
						<thead>
							<tr class="bg-slate-900 text-white">
								<th class="px-4 py-3 text-left text-sm sm:text-base uppercase tracking-wide font-bold">Heure</th>
								<th class="px-4 py-3 text-left text-sm sm:text-base uppercase tracking-wide font-bold">Artiste</th>
								<th class="px-4 py-3 text-left text-sm sm:text-base uppercase tracking-wide font-bold">Scène</th>
							</tr>
						</thead>
						<tbody>
							{artistesJour.map((artiste: any, i: number) => (
								<tr class={`border-b border-slate-200 hover:bg-slate-50 transition ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50/50'}`}>
									<td class="px-4 py-3 text-slate-900 font-semibold text-sm sm:text-base whitespace-nowrap">
										{formatHeure(artiste.date_de_representation)}
									</td>
									<td class="px-4 py-3 text-sm sm:text-base">
										<a href={`/artistes/${artiste.id}`} class="text-slate-900 font-semibold hover:text-blue-600 transition underline">
											{artiste.nom}
										</a>
									</td>
									<td class="px-4 py-3 text-slate-700 text-sm sm:text-base">
										{artiste.scene ? sceneMap.get(artiste.scene) || 'Non renseignée' : 'Non renseignée'}
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		))}

		{grouped.size === 0 && (
			<p class="text-center text-slate-500 text-lg">Aucun artiste programmé pour le moment.</p>
		)}

		<div class="flex justify-center mt-8">
			<a 
				href="/programme.pdf" 
				download="programme.pdf"
				class="inline-block px-8 py-4 border-2 border-slate-900 text-slate-900 font-bold uppercase tracking-widest rounded-full hover:bg-slate-900 hover:text-white transition text-sm sm:text-base"
			>
				Télécharger le programme
			</a>
		</div>
	</section>
</Layout>