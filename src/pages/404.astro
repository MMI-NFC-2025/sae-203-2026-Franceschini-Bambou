---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jumelages - Erreur 404">
	<section class="w-full py-24 px-4 flex items-center justify-center min-h-screen">
		<div class="max-w-2xl mx-auto text-center">
			<h1 class="text-6xl sm:text-7xl font-bold text-slate-900 mb-6 uppercase tracking-wide">
				404
			</h1>

			<p class="text-xl sm:text-2xl text-slate-700 mb-8 font-semibold">
				Oups ! La page que vous recherchez n'existe pas.
			</p>

			<p class="text-base sm:text-lg text-slate-600 mb-12 leading-relaxed">
				Il semble que vous ayez suivi un lien brisé ou que vous vous soyez trompé d'adresse.
				Ne vous inquiétez pas, vous pouvez retourner sur notre site en cliquant ci-dessous.
			</p>

			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a 
					href="/" 
					class="inline-block px-8 py-4 bg-slate-900 text-white font-bold uppercase tracking-widest rounded-lg hover:bg-slate-800 transition duration-300"
				>
					Retour à l'accueil
				</a>
				<a 
					href="/artiste" 
					class="inline-block px-8 py-4 border-2 border-slate-900 text-slate-900 font-bold uppercase tracking-widest rounded-lg hover:bg-slate-900 hover:text-white transition duration-300"
				>
					Voir les artistes
				</a>
			</div>

			<div class="mt-16 text-slate-400">
				<p class="text-sm">Vous pouvez également explorer :</p>
				<nav class="flex flex-wrap justify-center gap-6 mt-4">
					<a href="/scene" class="text-slate-600 hover:text-slate-900 font-semibold transition">Scènes</a>
					<a href="/programme" class="text-slate-600 hover:text-slate-900 font-semibold transition">Programmes</a>
					<a href="/infosPratiques" class="text-slate-600 hover:text-slate-900 font-semibold transition">Infos Pratiques</a>
					<a href="/contact" class="text-slate-600 hover:text-slate-900 font-semibold transition">Contact</a>
				</nav>
			</div>
		</div>
	</section>
</Layout>
