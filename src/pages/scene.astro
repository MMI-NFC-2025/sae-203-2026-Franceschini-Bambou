---
import Layout from '../layouts/Layout.astro';
import { getImageUrl, scenesName } from '../../backend/backend.mjs';

const scenes = await scenesName();
---

<Layout title="Jumelages - Scènes">
	<section class="w-full py-12 px-4">
		<h1 class="text-4xl sm:text-5xl font-bold text-slate-900 text-center mb-12 uppercase tracking-wide">
			LES SCÈNES
		</h1>

		<div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{scenes.map((scene: any) => {
				const imageUrl = scene.photo ? getImageUrl(scene, scene.photo) : '';
				return (
					<a href={`/scenes/${scene.id}`} class="group cursor-pointer">
						<div class="relative overflow-hidden rounded-lg shadow-lg mb-4 h-64">
							{imageUrl && (
								<img 
									src={imageUrl} 
									alt={scene.nom}
									class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
								/>
							)}
							{!imageUrl && (
								<div class="w-full h-full bg-slate-200 flex items-center justify-center">
									<p class="text-slate-600">Pas d'image disponible</p>
								</div>
							)}
						</div>
						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition">
							{scene.nom}
						</h2>
					</a>
				);
			})}
		</div>

		{scenes.length === 0 && (
			<div class="text-center py-12">
				<p class="text-lg text-slate-600">Aucune scène disponible pour le moment</p>
			</div>
		)}
	</section>
</Layout>