---
import Layout from '../layouts/Layout.astro';
import Carousel from '../components/Carousel.astro';
import PocketBase from 'pocketbase';

const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL || 'https://jumelages.bambou-franceschini.fr';
const pb = new PocketBase(pbUrl);
let scenes = [];
try {
  scenes = await pb.collection('scene').getFullList();
} catch (e) {
  console.error('Erreur PocketBase (scenes):', e);
}
---

<Layout title="Jumelages - Accueil">

	<div class="w-full bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/images/acceuil-header.avif'); aspect-ratio: 16 / 9; min-height: 600px;">
	</div>

	<nav class="flex justify-center gap-4 sm:gap-6 md:gap-8 list-none m-0 py-6 sm:py-8 md:py-10 px-4 flex-wrap w-full box-border">
		<a href="/programme" class="text-base sm:text-lg md:text-xl lg:text-2xl text-slate-900 underline uppercase tracking-wide font-medium">Programme</a>
		<a href="/artiste" class="text-base sm:text-lg md:text-xl lg:text-2xl text-slate-900 underline uppercase tracking-wide font-medium">Artistes</a>
		<a href="/infosPratiques" class="text-base sm:text-lg md:text-xl lg:text-2xl text-slate-900 underline uppercase tracking-wide font-medium">Infos Pratiques</a>
	</nav>

	<div class="text-center py-6 sm:py-8 md:py-10 px-4">
		<h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-slate-900 m-0 tracking-wider uppercase font-bold">
			29.30 août
		</h2>
	</div>

	<div class="flex justify-center py-6 sm:py-8 md:py-10">
		<a href="/billeterie" class="w-40 h-40 sm:w-48 sm:h-48 md:w-52 md:h-52 p-1.5 bg-transparent hover:opacity-80 transition inline-block">
			<img src="/assets/icones/bouton/bouton billeterie.svg" alt="Bouton billeterie" />
		</a>
	</div>

	<h2 class="text-3xl sm:text-4xl font-semibold text-slate-900 text-center mt-4 mb-2 px-2">Scènes</h2>
	<Carousel scenes={scenes} />
</Layout>

<script>