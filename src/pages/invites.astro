---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const invites = [
	{
		nom: "DJ Sunset",
		description: "DJ renommé pour ses sets électroniques envoûtants",
		genre: "Électro",
	},
	{
		nom: "Les Harmoniques",
		description: "Groupe de musique acoustique aux mélodies captivantes",
		genre: "Acoustique",
	},
	{
		nom: "Electric Waves",
		description: "Duo de producteurs aux sons futuristes",
		genre: "Électro",
	},
	{
		nom: "Nuit Blanche",
		description: "Collectif artistique mêlant musique et performance",
		genre: "Expérimental",
	},
	{
		nom: "Stellar Sound",
		description: "DJ international aux influences house et techno",
		genre: "House",
	},
	{
		nom: "Morning Light",
		description: "Artiste solo aux compositions ambient relaxantes",
		genre: "Ambient",
	},
	{
		nom: "Urban Beat",
		description: "Groupe de hip-hop alternatif aux textes engagés",
		genre: "Hip-hop",
	},
	{
		nom: "Acoustic Dreams",
		description: "Duo folk aux harmonies vocales envoûtantes",
		genre: "Folk",
	},
];
---

<Layout title="Invités - Jumelages">
	<Header />
	
	<main class="pt-32 pb-20 px-6">
		<div class="max-w-6xl mx-auto">
			<h1 class="font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold text-[var(--color-foreground)] mb-4 text-center">
				Les invités
			</h1>
			<p class="text-[var(--color-muted)] text-center mb-16 max-w-2xl mx-auto">
				Découvrez les artistes qui feront vibrer le festival Jumelages les 29 et 30 août
			</p>
			
			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{invites.map((invite) => (
					<article class="group p-6 rounded-2xl bg-[var(--color-secondary)] hover:bg-[var(--color-secondary)]/80 transition-all hover:-translate-y-1">
						<div class="w-full aspect-square rounded-xl bg-[var(--color-background)] mb-4 flex items-center justify-center overflow-hidden">
							<span class="font-[family-name:var(--font-display)] text-4xl font-bold text-[var(--color-primary)] opacity-30 group-hover:opacity-60 transition-opacity">
								{invite.nom.charAt(0)}
							</span>
						</div>
						
						<span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-3">
							{invite.genre}
						</span>
						
						<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
							{invite.nom}
						</h2>
						
						<p class="text-sm text-[var(--color-muted)] leading-relaxed">
							{invite.description}
						</p>
					</article>
				))}
			</div>
		</div>
	</main>
	
	<Footer />
</Layout>
