---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Infos pratiques - Jumelages">
	<Header />
	
	<main class="pt-32 pb-20 px-6">
		<div class="max-w-4xl mx-auto">
			<h1 class="font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold text-[var(--color-foreground)] mb-4 text-center">
				Infos pratiques
			</h1>
			<p class="text-[var(--color-muted)] text-center mb-16">
				Tout ce qu'il faut savoir pour profiter du festival
			</p>
			
			<div class="grid gap-8">
				<!-- Dates et horaires -->
				<section class="p-6 md:p-8 rounded-2xl bg-[var(--color-secondary)]">
					<div class="flex items-start gap-4">
						<div class="p-3 rounded-xl bg-[var(--color-primary)]/10">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
						</div>
						<div>
							<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2">
								Dates et horaires
							</h2>
							<p class="text-[var(--color-accent)] mb-4">
								Le festival se déroule les <strong class="text-[var(--color-primary)]">29 et 30 août 2024</strong>
							</p>
							<ul class="space-y-2 text-[var(--color-muted)]">
								<li>Samedi 29 août : 14h00 - 00h00</li>
								<li>Dimanche 30 août : 14h00 - 23h00</li>
							</ul>
						</div>
					</div>
				</section>
				
				<!-- Lieu -->
				<section class="p-6 md:p-8 rounded-2xl bg-[var(--color-secondary)]">
					<div class="flex items-start gap-4">
						<div class="p-3 rounded-xl bg-[var(--color-primary)]/10">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</div>
						<div>
							<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2">
								Lieu
							</h2>
							<p class="text-[var(--color-accent)] mb-2">
								Parc du centre-ville
							</p>
							<p class="text-[var(--color-muted)]">
								123 Avenue des Festivals<br>
								75000 Paris
							</p>
						</div>
					</div>
				</section>
				
				<!-- Accès -->
				<section class="p-6 md:p-8 rounded-2xl bg-[var(--color-secondary)]">
					<div class="flex items-start gap-4">
						<div class="p-3 rounded-xl bg-[var(--color-primary)]/10">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<div>
							<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2">
								Comment venir
							</h2>
							<div class="space-y-4">
								<div>
									<h3 class="text-[var(--color-accent)] font-medium mb-1">En transports en commun</h3>
									<p class="text-[var(--color-muted)]">
										Métro ligne 1 - Station "Festival"<br>
										Bus 42, 56, 78 - Arrêt "Parc Central"
									</p>
								</div>
								<div>
									<h3 class="text-[var(--color-accent)] font-medium mb-1">En voiture</h3>
									<p class="text-[var(--color-muted)]">
										Parking gratuit à proximité (500 places)
									</p>
								</div>
							</div>
						</div>
					</div>
				</section>
				
				<!-- Tarifs -->
				<section class="p-6 md:p-8 rounded-2xl bg-[var(--color-secondary)]">
					<div class="flex items-start gap-4">
						<div class="p-3 rounded-xl bg-[var(--color-primary)]/10">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
							</svg>
						</div>
						<div>
							<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2">
								Tarifs
							</h2>
							<div class="space-y-2">
								<div class="flex justify-between items-center py-2 border-b border-[var(--color-muted)]/20">
									<span class="text-[var(--color-accent)]">Pass 1 jour</span>
									<span class="font-semibold text-[var(--color-foreground)]">25€</span>
								</div>
								<div class="flex justify-between items-center py-2 border-b border-[var(--color-muted)]/20">
									<span class="text-[var(--color-accent)]">Pass 2 jours</span>
									<span class="font-semibold text-[var(--color-foreground)]">40€</span>
								</div>
								<div class="flex justify-between items-center py-2">
									<span class="text-[var(--color-accent)]">Tarif réduit (- de 18 ans)</span>
									<span class="font-semibold text-[var(--color-foreground)]">15€</span>
								</div>
							</div>
						</div>
					</div>
				</section>
				
				<!-- Contact -->
				<section class="p-6 md:p-8 rounded-2xl bg-[var(--color-secondary)]">
					<div class="flex items-start gap-4">
						<div class="p-3 rounded-xl bg-[var(--color-primary)]/10">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
						</div>
						<div>
							<h2 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-foreground)] mb-2">
								Contact
							</h2>
							<p class="text-[var(--color-muted)] mb-4">
								Une question ? N'hésitez pas à nous contacter.
							</p>
							<a href="mailto:contact@jumelages.fr" class="inline-flex items-center gap-2 text-[var(--color-primary)] hover:underline">
								contact@jumelages.fr
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
								</svg>
							</a>
						</div>
					</div>
				</section>
			</div>
		</div>
	</main>
	
	<Footer />
</Layout>
